generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id              String   @id @default(cuid())
  method          String
  plannedDuration Int
  actualDuration  Int
  completedAt     DateTime
  createdAt       DateTime @default(now())
}
